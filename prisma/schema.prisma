generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// Este modelo es el MVP de nuestra Fase 1
model Company {
  id              String   @id @default(uuid())
  ownerId         String   @unique
  companyName     String   @unique
  ceoName         String   @default("Nuevo CEO")
  
  // Finanzas Base
  liquidCash      Float    @default(100000.0)
  
  //Recursos Humanos
  programmers     Int      @default(0) // Productivos
  analysts        Int      @default(0) // I+D
  saboteurs       Int      @default(0) // Ataque

  //Infraestructura
  hqCount         Int      @default(0)
  officeCount     Int      @default(0)
  datacenterCount Int      @default(0)
  basementCount   Int      @default(0)

  //Nivel tecnologico global
  hqLevel         Int      @default(1)
  officeLevel     Int      @default(1)
  datacenterLevel Int      @default(1)
  basementLevel   Int      @default(1)
    
  lastUpdated     DateTime @default(now())
  createdAt       DateTime @default(now())
}
