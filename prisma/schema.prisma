generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// Este modelo es el MVP de nuestra Fase 1
model Company {
  id              String   @id @default(uuid())
  ownerId         String   @unique
  companyName     String   @unique
  ceoName         String   @default("Nuevo CEO")
  hqLevel         Int      @default(1)
  
  // Finanzas Base
  liquidCash      Float    @default(100000.0)
  
  //Recursos Humanos
  programmers     Int      @default(0) // Productivos
  analysts        Int      @default(0) // I+D
  saboteurs       Int      @default(0) // Ataque

  //Infraestructura
  facilities      Facility[] 
  
  lastUpdated     DateTime @default(now())
  createdAt       DateTime @default(now())
}

//El inventario de edificios de cada jugador
model Facility {
  id          String   @id @default(uuid())
  companyId   String
  type        String   // "OFFICE", "DATACENTER", "BASEMENT"
  level       Int      @default(1)
  
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}